---
import SectionHeader from '@/components/SectionHeader.astro'
import SectionShell from '@/components/SectionShell.astro'
import { faqItems } from '@/data/home'
---

<SectionShell className='flex flex-col gap-7'>
  <SectionHeader eyebrow='FAQ' title='Questions that come up early.' reveal titleClassName='max-w-[14ch] text-[clamp(2rem,5vw,3.35rem)]' />

  <div class='grid gap-4'>
    {faqItems.map((item) => (
      <details class='rounded-[1.35rem] border border-white/8 bg-white/4 px-[1.1rem] py-4' data-reveal>
        <summary class='cursor-pointer list-none font-display text-[1.02rem] text-white [&::-webkit-details-marker]:hidden'>
          {item.question}
        </summary>
        <p class='mt-[0.85rem] max-w-[64rem] leading-[1.82] text-slate-200/78'>{item.answer}</p>
      </details>
    ))}
  </div>
</SectionShell>
