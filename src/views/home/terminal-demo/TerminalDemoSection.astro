---
import SectionHeader from '@/components/SectionHeader.astro'
import SectionShell from '@/components/SectionShell.astro'
import { installOnboardNotes, terminalScenarios } from '@/data/home'

import TerminalScene from './TerminalScene.astro'
---

<SectionShell id='install-flow' className='flex flex-col gap-8'>
  <SectionHeader
    eyebrow='First run'
    title='Install, onboard, and start organizing.'
    copy='The demo mirrors the real CLI flow: install the binary, run onboarding, and confirm the project is managed before you start reorganizing skills.'
    titleClassName='max-w-[18ch] text-[clamp(2.2rem,5vw,3.75rem)]'
    copyClassName='max-w-[56rem] text-[1.08rem] leading-[1.9]'
    reveal
  />

  <div class='grid items-stretch gap-6 lg:grid-cols-[minmax(0,1.4fr)_minmax(18rem,0.8fr)]'>
    <TerminalScene scenarios={terminalScenarios} />

    <div class='grid gap-4'>
      {installOnboardNotes.map((note) => (
        <article
          class='flex flex-col gap-3 rounded-[1.6rem] border border-white/8 bg-white/4 px-5 py-[1.2rem]'
          data-reveal
        >
          <p class='font-display text-[0.74rem] uppercase tracking-[0.28em] text-amber-300/74'>
            {note.step}
          </p>
          <h3 class='text-[1.28rem] text-white'>{note.title}</h3>
          <p class='leading-[1.82]'>{note.body}</p>
        </article>
      ))}
    </div>
  </div>
</SectionShell>
