---
import type { CollectionEntry } from 'astro:content'
import { getCollection, render } from 'astro:content'

import DocsLayout from '@/layouts/DocsLayout.astro'
import { trimCollectionSlug } from '@/lib/docs'

export async function getStaticPaths() {
  const entries = await getCollection('docs')

  return entries.map((entry: CollectionEntry<'docs'>) => ({
    params: {
      section: entry.data.section,
      slug: trimCollectionSlug(entry.id),
    },
    props: { entry, entries },
  }))
}

type Props = {
  entry: CollectionEntry<'docs'>
  entries: CollectionEntry<'docs'>[]
}

const { entry, entries } = Astro.props as Props
const { Content, headings } = await render(entry)
const currentPath = `/docs/${entry.data.section}/${trimCollectionSlug(entry.id)}`
const sectionLabel = entry.data.section === 'guides' ? 'Guide' : 'Reference'
---

<DocsLayout
  title={entry.data.title}
  description={entry.data.description}
  entries={entries}
  headings={headings}
  currentPath={currentPath}
  sectionLabel={sectionLabel}
>
  <Content />
</DocsLayout>
