import AdvantagesSection from '@/views/home/components/advantages/AdvantagesSection.astro'
import CompatibilitySection from '@/views/home/components/compatibility/CompatibilitySection.astro'
import DocsCtaSection from '@/views/home/components/docs-cta/DocsCtaSection.astro'
import FaqSection from '@/views/home/components/faq/FaqSection.astro'
