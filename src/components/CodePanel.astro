---
import CopyButton from '@/components/CopyButton.astro'

type Props = {
  title: string
  eyebrow?: string
  code: string[]
  footer?: string
  accent?: 'cyan' | 'violet' | 'amber'
}

const { title, eyebrow, code, footer, accent = 'cyan' } = Astro.props as Props

const accentClass = {
  cyan: 'shadow-[inset_0_1px_0_rgba(255,255,255,0.05),0_32px_80px_rgba(35,189,226,0.15)]',
  violet:
    'shadow-[inset_0_1px_0_rgba(255,255,255,0.05),0_32px_80px_rgba(135,79,255,0.18)]',
  amber:
    'shadow-[inset_0_1px_0_rgba(255,255,255,0.05),0_32px_80px_rgba(255,182,73,0.16)]',
}[accent]
---

<div
  class:list={[
    'relative min-w-0 overflow-hidden rounded-[1.75rem] border border-[rgba(154,188,255,0.16)] bg-[linear-gradient(180deg,rgba(7,14,29,0.88),rgba(7,12,25,0.78))] before:absolute before:inset-0 before:-translate-x-[120%] before:bg-[linear-gradient(120deg,transparent_16%,rgba(255,255,255,0.06),transparent_32%)] before:content-[""]',
    accentClass,
  ]}
  data-reveal
>
  <div
    class="flex items-start justify-between gap-4 border-b border-white/10 px-5 py-4"
  >
    <div class="min-w-0">
      {
        eyebrow && (
          <p class="font-display text-xs uppercase tracking-[0.32em] text-slate-400">
            {eyebrow}
          </p>
        )
      }
      <h3 class="mt-2 text-lg text-white">{title}</h3>
    </div>
    <CopyButton copyText={code.join('\n')} title={title} />
  </div>

  <div class="min-w-0 overflow-x-auto px-5 py-5 md:overflow-x-auto">
    <pre
      class="min-w-0 whitespace-pre-wrap break-words font-code text-sm leading-7 text-slate-200 md:whitespace-pre md:break-normal"><code>{code.join('\n')}</code></pre>
  </div>

  {
    footer && (
      <p class="border-t border-white/10 px-5 py-3 text-sm text-slate-400">
        {footer}
      </p>
    )
  }
</div>
