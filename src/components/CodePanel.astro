---
type Props = {
  title: string
  eyebrow?: string
  code: string[]
  footer?: string
  accent?: 'cyan' | 'violet' | 'amber'
}

const { title, eyebrow, code, footer, accent = 'cyan' } = Astro.props as Props
---

<div class:list={['code-panel', `code-panel--${accent}`]} data-reveal>
  <div class='flex items-start justify-between gap-4 border-b border-white/10 px-5 py-4'>
    <div>
      {eyebrow && <p class='font-display text-xs uppercase tracking-[0.32em] text-slate-400'>{eyebrow}</p>}
      <h3 class='mt-2 text-lg text-white'>{title}</h3>
    </div>
    <button
      type='button'
      class='copy-button'
      data-copy-text={code.join('\n')}
      aria-label={`Copy ${title}`}
    >
      Copy
    </button>
  </div>

  <div class='overflow-x-auto px-5 py-5'>
    <pre class='font-code text-sm leading-7 text-slate-200'><code>{code.join('\n')}</code></pre>
  </div>

  {footer && <p class='border-t border-white/10 px-5 py-3 text-sm text-slate-400'>{footer}</p>}
</div>
