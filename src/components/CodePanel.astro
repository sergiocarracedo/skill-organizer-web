---
type Props = {
  title: string
  eyebrow?: string
  code: string[]
  footer?: string
  accent?: 'cyan' | 'violet' | 'amber'
}

const { title, eyebrow, code, footer, accent = 'cyan' } = Astro.props as Props
---

<div class:list={['code-panel', `code-panel--${accent}`]} data-reveal>
  <div class='flex items-start justify-between gap-4 border-b border-white/10 px-5 py-4'>
    <div class='min-w-0'>
      {eyebrow && <p class='font-display text-xs uppercase tracking-[0.32em] text-slate-400'>{eyebrow}</p>}
      <h3 class='mt-2 text-lg text-white'>{title}</h3>
    </div>
    <button
      type='button'
      class='copy-button'
      data-copy-text={code.join('\n')}
      aria-label={`Copy ${title}`}
    >
      Copy
    </button>
  </div>

  <div class='min-w-0 overflow-x-auto px-5 py-5 md:overflow-x-auto'>
    <pre class='code-panel__pre font-code text-sm leading-7 text-slate-200'><code>{code.join('\n')}</code></pre>
  </div>

  {footer && <p class='border-t border-white/10 px-5 py-3 text-sm text-slate-400'>{footer}</p>}
</div>

<style>
  .code-panel {
    min-width: 0;
  }

  .code-panel__pre {
    min-width: 0;
    white-space: pre-wrap;
    overflow-wrap: anywhere;
    word-break: break-word;
  }

  @media (min-width: 768px) {
    .code-panel__pre {
      white-space: pre;
      overflow-wrap: normal;
      word-break: normal;
    }
  }
</style>
