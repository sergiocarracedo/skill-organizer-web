---
const withBase = (path: string) => `${import.meta.env.BASE_URL.replace(/\/$/, '')}${path}`
---

<footer class='border-t border-white/10 bg-slate-950/80'>
  <div class='mx-auto grid max-w-7xl gap-8 px-5 py-10 text-sm text-slate-300/70 sm:px-8 lg:grid-cols-[1.2fr_0.8fr]'>
    <div>
      <p class='font-display text-lg uppercase tracking-[0.2em] text-slate-100'>Skill Organizer</p>
      <p class='mt-3 max-w-2xl'>
        Keep your skill source tree readable, expressive, and grouped the way humans want to edit it while
        preserving the flat compatibility layer AI tools already expect.
      </p>
    </div>

    <div class='grid gap-2 sm:justify-self-end sm:text-right'>
      <a href={withBase('/docs')} class='transition hover:text-white'>Docs</a>
      <a href='https://github.com/sergiocarracedo/skill-organizer' target='_blank' rel='noreferrer' class='transition hover:text-white'>
        GitHub repository
      </a>
      <a href='https://sergiocarracedo.es/' target='_blank' rel='noreferrer' class='transition hover:text-white'>
        Sergio Carracedo
      </a>
    </div>
  </div>
</footer>
