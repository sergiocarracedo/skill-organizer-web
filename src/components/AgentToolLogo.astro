---
import AppleLogo from '@/components/logos/Apple.astro'
import AntigravityLogo from '@/components/logos/Antigravity.astro'
import ClaudeLogo from '@/components/logos/Claude.astro'
import CodexLogo from '@/components/logos/Codex.astro'
import CursorLogo from '@/components/logos/Cursor.astro'
import LinuxLogo from '@/components/logos/Linux.astro'
import OpencodeLogo from '@/components/logos/Opencode.astro'

type ToolId =
  | 'claude'
  | 'opencode'
  | 'codex'
  | 'cursor'
  | 'antigravity'
  | 'agents'
  | 'macos'
  | 'linux'

type Props = {
  id: ToolId
  name: string
  compact?: boolean
  iconOnly?: boolean
}

const { id, name, compact = false, iconOnly = false } = Astro.props as Props
---

<span
  class:list={[
    'agent-tool-logo',
    compact ? 'agent-tool-logo--compact' : '',
    iconOnly ? 'agent-tool-logo--icon-only' : '',
  ]}
  title={name}
  aria-label={name}
>
  <span class='agent-tool-logo__mark' aria-hidden='true'>
    {id === 'claude' && (
      <ClaudeLogo className='h-5 w-5' />
    )}

    {id === 'opencode' && (
      <OpencodeLogo className='h-5 w-5' />
    )}

    {id === 'codex' && (
      <CodexLogo className='h-5 w-5' />
    )}

    {id === 'cursor' && (
      <CursorLogo className='h-5 w-5' />
    )}

    {id === 'antigravity' && (
      <AntigravityLogo className='h-5 w-5' />
    )}

    {id === 'agents' && (
      <svg viewBox='0 0 24 24' class='h-5 w-5' fill='none' xmlns='http://www.w3.org/2000/svg'>
        <path d='M5.8 7h12.4v10H5.8z' stroke='currentColor' stroke-width='1.8'></path>
        <path d='M8.8 10.2h6.4M8.8 13.7h4.4' stroke='currentColor' stroke-width='1.8' stroke-linecap='round'></path>
        <path d='M8 4.8h8' stroke='currentColor' stroke-width='1.8' stroke-linecap='round' opacity='.72'></path>
      </svg>
    )}

    {id === 'macos' && (
      <AppleLogo className='h-5 w-5' />
    )}

    {id === 'linux' && (
      <LinuxLogo className='h-5 w-5' />
    )}
  </span>

  {!iconOnly && <span class='agent-tool-logo__name'>{name}</span>}
</span>

<style>
  .agent-tool-logo {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    border: 1px solid rgba(255, 255, 255, 0.09);
    border-radius: 999px;
    padding: 0.5rem 0.78rem;
    color: rgba(240, 246, 255, 0.76);
    background: rgba(255, 255, 255, 0.03);
    transition:
      border-color 180ms ease,
      color 180ms ease,
      background-color 180ms ease;
  }

  .agent-tool-logo:hover {
    border-color: rgba(255, 255, 255, 0.16);
    color: rgba(255, 255, 255, 0.92);
    background: rgba(255, 255, 255, 0.045);
  }

  .agent-tool-logo--compact {
    padding: 0.46rem 0.72rem;
    gap: 0.48rem;
  }

  .agent-tool-logo--icon-only {
    justify-content: center;
    padding: 0.58rem;
    gap: 0;
    width: 2.45rem;
    height: 2.45rem;
  }

  .agent-tool-logo__mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.2rem;
    height: 1.2rem;
    color: currentColor;
    flex: none;
  }

  .agent-tool-logo__name {
    font-family: var(--font-display);
    font-size: 0.72rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .agent-tool-logo--compact .agent-tool-logo__name {
    font-size: 0.68rem;
    letter-spacing: 0.14em;
  }
</style>
