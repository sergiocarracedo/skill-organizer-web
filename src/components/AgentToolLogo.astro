---
type ToolId = 'claude' | 'opencode' | 'codex' | 'cursor' | 'antigravity' | 'agents'

type Props = {
  id: ToolId
  name: string
}

const { id, name } = Astro.props as Props
---

<span class='relative inline-flex items-center justify-center rounded-full p-1.5 text-white/60 transition hover:text-white/88' title={name} aria-label={name}>
  {id === 'claude' && (
    <svg viewBox='0 0 24 24' class='h-6 w-6' fill='none' xmlns='http://www.w3.org/2000/svg' aria-hidden='true'>
      <path d='M12 2.6 16 4.9l1.2 4.7-3.4 3.2-4.7-1.2L7.8 6.9 12 2.6Z' fill='currentColor' opacity='.95'></path>
      <path d='M5.2 9.3 9 12.1l-.8 4.7-4.2 1.8L2.8 13l2.4-3.7Z' fill='currentColor' opacity='.78'></path>
      <path d='m18.8 9.3 2.4 3.7-1.2 5.6-4.2-1.8-.8-4.7 3.8-2.8Z' fill='currentColor' opacity='.78'></path>
      <path d='m9.4 17.8 2.6-1.7 2.6 1.7L14 21.4h-4l-.6-3.6Z' fill='currentColor'></path>
    </svg>
  )}

  {id === 'opencode' && (
    <svg viewBox='0 0 24 24' class='h-6 w-6' fill='none' xmlns='http://www.w3.org/2000/svg' aria-hidden='true'>
      <circle cx='12' cy='12' r='8.8' stroke='currentColor' stroke-width='2'></circle>
      <circle cx='12' cy='12' r='4.1' stroke='currentColor' stroke-width='2' opacity='.78'></circle>
      <path d='M12 3.2v4M20.8 12h-4M12 20.8v-4M3.2 12h4' stroke='currentColor' stroke-width='2' stroke-linecap='round'></path>
    </svg>
  )}

  {id === 'codex' && (
    <svg viewBox='0 0 24 24' class='h-6 w-6' fill='none' xmlns='http://www.w3.org/2000/svg' aria-hidden='true'>
      <path d='M12 2.8 20.2 7v10L12 21.2 3.8 17V7L12 2.8Z' stroke='currentColor' stroke-width='2'></path>
      <path d='m7.2 9.3 4.8-2.7 4.8 2.7v5.4L12 17.4l-4.8-2.7V9.3Z' fill='currentColor' opacity='.72'></path>
    </svg>
  )}

  {id === 'cursor' && (
    <svg viewBox='0 0 24 24' class='h-6 w-6' fill='none' xmlns='http://www.w3.org/2000/svg' aria-hidden='true'>
      <path d='M12 3.1 18.9 7v10L12 20.9 5.1 17V7L12 3.1Z' stroke='currentColor' stroke-width='1.8'></path>
      <path d='M12 7.2 15.9 9.5v5L12 16.8l-3.9-2.3v-5L12 7.2Z' fill='currentColor'></path>
    </svg>
  )}

  {id === 'antigravity' && (
    <svg viewBox='0 0 24 24' class='h-6 w-6' fill='none' xmlns='http://www.w3.org/2000/svg' aria-hidden='true'>
      <path d='M12 3.1 18.6 6.8v7.4L12 17.9l-6.6-3.7V6.8L12 3.1Z' stroke='currentColor' stroke-width='1.8'></path>
      <path d='M12 7.1 15.3 9v3.9L12 14.8l-3.3-1.9V9L12 7.1Z' fill='currentColor' opacity='.78'></path>
      <path d='M12 17.9v3' stroke='currentColor' stroke-width='1.8' stroke-linecap='round'></path>
    </svg>
  )}

  {id === 'agents' && (
    <svg viewBox='0 0 24 24' class='h-6 w-6' fill='none' xmlns='http://www.w3.org/2000/svg' aria-hidden='true'>
      <path d='M6 7.2h12v9.6H6z' stroke='currentColor' stroke-width='1.8'></path>
      <path d='M9 10.1h6M9 13.9h4.2' stroke='currentColor' stroke-width='1.8' stroke-linecap='round'></path>
      <path d='M8 4.8h8' stroke='currentColor' stroke-width='1.8' stroke-linecap='round' opacity='.72'></path>
    </svg>
  )}
</span>
