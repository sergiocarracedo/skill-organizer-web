---
import { advantageItems } from '@/data/home'
---

<section class='advantages-section'>
  <div class='advantages-section__panel' data-reveal>
    <div class='advantages-section__intro'>
      <p class='advantages-section__eyebrow'>Why use it</p>
      <h2 class='advantages-section__title'>A cleaner way to manage skills long term.</h2>
    </div>

    <ul class='advantages-section__list'>
      {advantageItems.map((item) => (
        <li>{item}</li>
      ))}
    </ul>
  </div>
</section>

<style>
  .advantages-section {
    display: flex;
    max-width: 84rem;
    margin: 0 auto;
    padding: 6rem 1.5rem 0;
  }

  .advantages-section__panel {
    display: grid;
    width: 100%;
    gap: 1.5rem;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 2rem;
    padding: 1.6rem;
    background: linear-gradient(135deg, rgba(6, 13, 27, 0.98), rgba(15, 23, 43, 0.9), rgba(23, 15, 36, 0.82));
    box-shadow: 0 0 80px rgba(45, 118, 170, 0.12);
  }

  .advantages-section__intro {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .advantages-section__eyebrow {
    font-family: var(--font-display);
    font-size: 0.76rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: rgba(177, 225, 255, 0.72);
  }

  .advantages-section__title {
    max-width: 18ch;
    color: white;
    font-size: clamp(2.1rem, 5vw, 3.4rem);
  }

  .advantages-section__list {
    display: grid;
    gap: 0.9rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .advantages-section__list li {
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 1.25rem;
    padding: 1rem 1.05rem;
    background: rgba(255, 255, 255, 0.04);
    line-height: 1.75;
    color: rgba(238, 244, 255, 0.88);
  }

  .advantages-section__list li::before {
    content: '◈';
    margin-right: 0.7rem;
    color: rgba(255, 181, 73, 0.82);
  }

  @media (min-width: 960px) {
    .advantages-section {
      padding: 7rem 2rem 0;
    }

    .advantages-section__panel {
      grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
      padding: 2rem;
    }
  }
</style>
