---
import AgentToolLogo from '@/components/AgentToolLogo.astro'
import { compatibilityItems } from '@/data/home'
---

<section class='compatibility-section'>
  <div class='compatibility-section__copy' data-reveal>
    <p class='compatibility-section__eyebrow'>Compatibility</p>
    <h2 class='compatibility-section__title'>Use the best agent for the job.</h2>
    <p class='compatibility-section__body'>
      Keep one organized source tree and expose the flat target that each agent expects. Use generic `.agents`
      layouts where possible, or onboard directly into tool-specific targets without giving up structure.
    </p>
  </div>

  <div class='compatibility-section__supports' data-reveal>
    <span class='compatibility-section__supports-label'>Supports</span>
    <div class='compatibility-section__supports-strip'>
      {compatibilityItems.map((item) => (
        <AgentToolLogo id={item.id} name={item.name} />
      ))}
    </div>
  </div>
</section>

<style>
  .compatibility-section {
    display: grid;
    max-width: 84rem;
    margin: 0 auto;
    padding: 6rem 1.5rem 0;
    gap: 1.5rem;
    align-items: end;
  }

  .compatibility-section__copy {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .compatibility-section__eyebrow {
    font-family: var(--font-display);
    font-size: 0.76rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: rgba(177, 225, 255, 0.72);
  }

  .compatibility-section__title {
    max-width: 18ch;
    color: white;
    font-size: clamp(2.1rem, 5vw, 3.5rem);
  }

  .compatibility-section__body {
    max-width: 56rem;
    font-size: 1.06rem;
    line-height: 1.88;
    color: rgba(235, 244, 255, 0.78);
  }

  .compatibility-section__supports {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    padding-top: 0.5rem;
  }

  .compatibility-section__supports-label {
    font-size: 0.78rem;
    color: rgba(255, 255, 255, 0.4);
  }

  .compatibility-section__supports-strip {
    display: flex;
    align-items: center;
    gap: 0.15rem;
  }

  @media (min-width: 960px) {
    .compatibility-section {
      padding: 7rem 2rem 0;
      grid-template-columns: minmax(0, 1.05fr) minmax(16rem, 0.95fr);
    }
  }
</style>
