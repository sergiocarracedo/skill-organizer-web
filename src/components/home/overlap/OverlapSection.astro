---
import { overlapDemoGroups } from '@/data/home'
---

<section class='overlap-section'>
  <div class='overlap-section__intro' data-reveal>
    <p class='overlap-section__eyebrow'>Skill overlap check</p>
    <h2 class='overlap-section__title'>Find overlapping skills before routing gets messy.</h2>
    <p class='overlap-section__copy'>
      `skill-organizer skill check-overlap` uses an installed agent to review your managed skills for duplicate
      or partial overlap, then groups the findings with explanations and cleanup guidance.
    </p>
  </div>

  <div class='overlap-section__surface' data-reveal>
    <div class='overlap-section__terminal'>
      <div class='overlap-section__terminal-bar'>
        <span></span>
        <span></span>
        <span></span>
        <p>skill-organizer skill check-overlap --tool claude</p>
      </div>

      <div class='overlap-section__terminal-body'>
        <p class='overlap-section__heading'># Potential Overlap Groups</p>

        <div class='overlap-section__groups'>
          {overlapDemoGroups.map((group) => (
            <article class='overlap-group'>
              <p class='overlap-group__title'>{group.title}</p>

              <div class='overlap-group__box'>
                <p class='overlap-group__label'>Skills:</p>
                <ul class='overlap-group__skills'>
                  {group.skills.map((skill) => (
                    <li>{skill}</li>
                  ))}
                </ul>

                <p class='overlap-group__label'>Overlap:</p>
                <p class='overlap-group__score'>
                  <span class:list={['overlap-group__marker', group.overlapType === 'Duplicate' && 'is-duplicate']}>■</span>
                  <span class:list={['overlap-group__type', group.overlapType === 'Duplicate' && 'is-duplicate']}>
                    {group.overlapType}
                  </span>
                  <span class:list={['overlap-group__value', group.overlapType === 'Duplicate' && 'is-duplicate']}>
                    ({group.score}/100)
                  </span>
                </p>

                <p class='overlap-group__label'>Why the overlap:</p>
                <p class='overlap-group__text'>{group.why}</p>

                <p class='overlap-group__label'>Recommendation:</p>
                <p class='overlap-group__text'>{group.recommendation}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .overlap-section {
    display: flex;
    max-width: 84rem;
    margin: 0 auto;
    padding: 6rem 1.5rem 0;
    flex-direction: column;
    gap: 2rem;
  }

  .overlap-section__intro {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .overlap-section__eyebrow {
    font-family: var(--font-display);
    font-size: 0.76rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: rgba(177, 225, 255, 0.72);
  }

  .overlap-section__title {
    max-width: 15ch;
    color: white;
    font-size: clamp(2.2rem, 5vw, 3.7rem);
  }

  .overlap-section__copy {
    max-width: 58rem;
    font-size: 1.08rem;
    line-height: 1.9;
    color: rgba(235, 244, 255, 0.78);
  }

  .overlap-section__terminal {
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 2rem;
    background: rgba(7, 11, 21, 0.94);
    box-shadow: 0 32px 90px rgba(7, 13, 26, 0.48);
  }

  .overlap-section__terminal-bar {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    padding: 0.9rem 1rem;
    background: rgba(255, 255, 255, 0.03);
  }

  .overlap-section__terminal-bar span {
    width: 0.72rem;
    height: 0.72rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.16);
  }

  .overlap-section__terminal-bar span:first-child {
    background: rgba(255, 109, 65, 0.84);
  }

  .overlap-section__terminal-bar span:nth-child(2) {
    background: rgba(255, 181, 73, 0.84);
  }

  .overlap-section__terminal-bar span:nth-child(3) {
    background: rgba(67, 238, 255, 0.84);
  }

  .overlap-section__terminal-bar p {
    margin-left: 0.7rem;
    font-family: var(--font-code);
    font-size: 0.82rem;
    color: rgba(235, 244, 255, 0.82);
  }

  .overlap-section__terminal-body {
    padding: 1.3rem 1.2rem 1.45rem;
    font-family: var(--font-code);
  }

  .overlap-section__heading {
    color: rgba(255, 204, 64, 0.92);
    font-size: 1.05rem;
    font-weight: 600;
  }

  .overlap-section__groups {
    display: grid;
    gap: 1.3rem;
    margin-top: 1.3rem;
  }

  .overlap-group {
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }

  .overlap-group__title {
    color: rgba(67, 238, 255, 0.92);
    font-weight: 700;
  }

  .overlap-group__box {
    border: 1px solid rgba(255, 255, 255, 0.18);
    padding: 1rem 1.05rem;
    background: rgba(255, 255, 255, 0.01);
  }

  .overlap-group__label {
    color: rgba(192, 104, 255, 0.92);
    font-weight: 700;
    margin-top: 0.5rem;
  }

  .overlap-group__label:first-child {
    margin-top: 0;
  }

  .overlap-group__skills {
    display: grid;
    gap: 0.15rem;
    list-style: none;
    padding: 0;
    margin: 0.25rem 0 0;
  }

  .overlap-group__skills li {
    color: rgba(93, 217, 255, 0.96);
  }

  .overlap-group__skills li::before {
    content: '- ';
    color: rgba(235, 244, 255, 0.68);
  }

  .overlap-group__score {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 0.25rem;
  }

  .overlap-group__marker,
  .overlap-group__type,
  .overlap-group__value {
    color: rgba(255, 202, 84, 0.94);
    font-weight: 700;
  }

  .overlap-group__marker.is-duplicate,
  .overlap-group__type.is-duplicate,
  .overlap-group__value.is-duplicate {
    color: rgba(255, 93, 126, 0.94);
  }

  .overlap-group__text {
    margin-top: 0.22rem;
    color: rgba(235, 244, 255, 0.82);
    line-height: 1.7;
  }

  @media (min-width: 960px) {
    .overlap-section {
      padding: 7rem 2rem 0;
    }
  }
</style>
