---
import { docsEntryCards } from '@/data/home'

const withBase = (path: string) => `${import.meta.env.BASE_URL.replace(/\/$/, '')}${path}`
---

<section class='docs-cta'>
  <div class='docs-cta__panel' data-reveal>
    <p class='docs-cta__eyebrow'>Documentation</p>
    <h2 class='docs-cta__title'>Pick the path you need.</h2>
    <p class='docs-cta__copy'>
      Start with install if you are new, onboarding if you are wiring up a skills location, or reference if you want the
      exact command surface for sync, service, overlap analysis, and completion scripts.
    </p>

    <div class='docs-cta__grid'>
      {docsEntryCards.map((card) => (
        <a class='docs-cta__card' href={withBase(card.href)}>
          <span class='docs-cta__card-title'>{card.title}</span>
          <span class='docs-cta__card-copy'>{card.copy}</span>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .docs-cta {
    display: flex;
    max-width: 84rem;
    margin: 0 auto;
    padding: 6rem 1.5rem 5rem;
  }

  .docs-cta__panel {
    display: flex;
    width: 100%;
    flex-direction: column;
    gap: 1rem;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 2rem;
    padding: 1.7rem;
    background: linear-gradient(135deg, rgba(6, 13, 27, 0.98), rgba(16, 29, 53, 0.86), rgba(51, 30, 8, 0.74));
    box-shadow: 0 0 80px rgba(45, 118, 170, 0.16);
  }

  .docs-cta__eyebrow {
    font-family: var(--font-display);
    font-size: 0.76rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: rgba(177, 225, 255, 0.72);
  }

  .docs-cta__title {
    max-width: 16ch;
    color: white;
    font-size: clamp(2.1rem, 5vw, 3.45rem);
  }

  .docs-cta__copy {
    max-width: 54rem;
    line-height: 1.88;
    color: rgba(236, 244, 255, 0.78);
  }

  .docs-cta__grid {
    display: grid;
    gap: 0.9rem;
    margin-top: 0.4rem;
  }

  .docs-cta__card {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 1.3rem;
    padding: 1rem 1.05rem;
    text-decoration: none;
    background: rgba(255, 255, 255, 0.05);
    transition: 180ms ease;
  }

  .docs-cta__card:hover {
    border-color: rgba(67, 238, 255, 0.28);
    background: rgba(255, 255, 255, 0.07);
  }

  .docs-cta__card-title {
    font-family: var(--font-display);
    font-size: 1.1rem;
    color: white;
  }

  .docs-cta__card-copy {
    line-height: 1.72;
    color: rgba(236, 244, 255, 0.72);
  }

  @media (min-width: 820px) {
    .docs-cta__grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media (min-width: 960px) {
    .docs-cta {
      padding: 7rem 2rem 6rem;
    }

    .docs-cta__panel {
      padding: 2rem;
    }
  }
</style>
