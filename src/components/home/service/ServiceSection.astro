---
import CodePanel from '@/components/CodePanel.astro'
import { servicePanels } from '@/data/home'
---

<section class='service-section'>
  <div class='service-section__intro' data-reveal>
    <p class='service-section__eyebrow'>Service and watch mode</p>
    <h2 class='service-section__title'>Stop treating sync like manual maintenance.</h2>
    <p class='service-section__copy'>
      Use watch mode while actively editing, or install the service when you want the flat target to stay current
      in the background.
    </p>
    <div class='service-section__chips'>
      <span>Foreground watch</span>
      <span>Watched registry</span>
      <span>Background service</span>
      <span>Log level control</span>
    </div>
  </div>

  <div class='service-section__panels'>
    <CodePanel
      eyebrow={servicePanels[0].eyebrow}
      title={servicePanels[0].title}
      code={servicePanels[0].commands}
      footer={servicePanels[0].note}
      accent='violet'
    />
    <CodePanel
      eyebrow={servicePanels[1].eyebrow}
      title={servicePanels[1].title}
      code={servicePanels[1].commands}
      footer={servicePanels[1].note}
      accent='amber'
    />
  </div>
</section>

<style>
  .service-section {
    display: flex;
    max-width: 80rem;
    margin: 0 auto;
    padding: 4.5rem 1.25rem 0;
    flex-wrap: wrap;
    gap: 1.25rem;
    align-items: flex-start;
  }

  .service-section__intro {
    display: flex;
    flex: 1 1 22rem;
    flex-direction: column;
    gap: 1rem;
  }

  .service-section__eyebrow {
    font-family: var(--font-display);
    font-size: 0.76rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: rgba(177, 225, 255, 0.72);
  }

  .service-section__title {
    max-width: 16ch;
    color: white;
    font-size: clamp(2rem, 5vw, 3.3rem);
  }

  .service-section__copy {
    max-width: 38rem;
    line-height: 1.85;
  }

  .service-section__chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
  }

  .service-section__chips span {
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 999px;
    padding: 0.55rem 0.85rem;
    font-size: 0.88rem;
    background: rgba(255, 255, 255, 0.04);
  }

  .service-section__panels {
    display: flex;
    flex: 1 1 36rem;
    min-width: 0;
    flex-direction: column;
    gap: 1rem;
  }

  @media (min-width: 900px) {
    .service-section {
      padding: 5rem 2rem 0;
    }
  }
</style>
