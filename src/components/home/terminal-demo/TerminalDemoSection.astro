---
import { installOnboardNotes, terminalScenarios } from '@/data/home'

import TerminalScene from './TerminalScene.astro'
---

<section class='home-section' id='install-flow'>
  <div class='home-section__header' data-reveal>
    <p class='home-section__eyebrow'>First run</p>
    <h2 class='home-section__title'>Install, onboard, and start organizing.</h2>
    <p class='home-section__copy'>
      The demo mirrors the real CLI flow: install the binary, run onboarding, and confirm the project is managed
      before you start reorganizing skills.
    </p>
  </div>

  <div class='terminal-demo__layout'>
    <TerminalScene scenarios={terminalScenarios} />

    <div class='terminal-demo__notes'>
      {installOnboardNotes.map((note) => (
        <article class='terminal-demo__note' data-reveal>
          <p class='terminal-demo__step'>{note.step}</p>
          <h3>{note.title}</h3>
          <p>{note.body}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .home-section {
    display: flex;
    max-width: 84rem;
    margin: 0 auto;
    padding: 6rem 1.5rem 0;
    flex-direction: column;
    gap: 2rem;
  }

  .home-section__header {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .home-section__eyebrow {
    font-family: var(--font-display);
    font-size: 0.76rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: rgba(177, 225, 255, 0.72);
  }

  .home-section__title {
    max-width: 18ch;
    color: white;
    font-size: clamp(2.2rem, 5vw, 3.75rem);
  }

  .home-section__copy {
    max-width: 56rem;
    font-size: 1.08rem;
    line-height: 1.9;
    color: rgba(235, 244, 255, 0.78);
  }

  .terminal-demo__layout {
    display: grid;
    gap: 1.5rem;
    align-items: stretch;
  }

  .terminal-demo__notes {
    display: grid;
    gap: 1rem;
  }

  .terminal-demo__note {
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 1.6rem;
    padding: 1.2rem 1.25rem;
    background: rgba(255, 255, 255, 0.04);
  }

  .terminal-demo__step {
    font-family: var(--font-display);
    font-size: 0.74rem;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: rgba(255, 181, 73, 0.74);
  }

  .terminal-demo__note h3 {
    color: white;
    font-size: 1.28rem;
  }

  .terminal-demo__note p {
    line-height: 1.82;
  }

  @media (min-width: 960px) {
    .home-section {
      padding: 7rem 2rem 0;
    }

    .terminal-demo__layout {
      grid-template-columns: minmax(0, 1.4fr) minmax(18rem, 0.8fr);
    }
  }
</style>
