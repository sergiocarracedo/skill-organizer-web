---
import type { TerminalChunk, TerminalLine, TerminalScenario } from '@/data/home'

type Props = {
  scenarios: TerminalScenario[]
}

const { scenarios } = Astro.props as Props

const renderLine = (line: TerminalLine) => {
  if (typeof line === 'string') {
    return [{ text: line, color: 'default', bold: false } satisfies TerminalChunk]
  }

  return line.map((chunk) => ({
    text: chunk.text,
    color: chunk.color ?? 'default',
    bold: chunk.bold ?? false,
  }))
}

const scenarioDuration = (scenario: TerminalScenario) =>
  scenario.events.reduce((total, event) => {
    if (event.type === 'wait' || event.type === 'progress') {
      return total + event.delay
    }

    return total + (event.delay ?? 520)
  }, 0)

const defaultPromptDelay = 640
const defaultOutputDelay = 520

const serializeScenarios = JSON.stringify(
  scenarios.map((scenario) => ({
    ...scenario,
    duration: scenarioDuration(scenario),
  })),
)
---

<div class='terminal-scene' data-reveal data-terminal-scene data-scenarios={serializeScenarios}>
  <div class='terminal-scene__chrome'>
    <span></span>
    <span></span>
    <span></span>
    <div class='terminal-scene__tabs'>
      {scenarios.map((scenario, index) => (
        <button
          class:list={['terminal-scene__tab', index === 0 && 'is-active']}
          type='button'
          data-tab={scenario.id}
        >
          {scenario.label}
        </button>
      ))}
    </div>
  </div>

  <div class='terminal-scene__meta'>
    {scenarios.map((scenario, index) => (
      <p
        class:list={['terminal-scene__description', index === 0 && 'is-active']}
        data-description={scenario.id}
      >
        {scenario.description}
      </p>
    ))}
  </div>

  <div class='terminal-scene__body'>
    {scenarios.map((scenario, index) => (
      <section
        class:list={[
          'terminal-panel',
          `terminal-panel--${scenario.accent}`,
          index === 0 && 'is-active',
        ]}
        data-panel={scenario.id}
      >
        <div class='terminal-stream' data-stream={scenario.id}></div>
      </section>
    ))}
  </div>
</div>

<script>
  const DEFAULT_PROMPT_DELAY = 640
  const DEFAULT_OUTPUT_DELAY = 520

  const sleep = (delay) => new Promise((resolve) => window.setTimeout(resolve, delay))

  const createPromptLine = (content, prompt = '$') => {
    const row = document.createElement('div')
    row.className = 'terminal-line terminal-line--prompt'

    const promptEl = document.createElement('span')
    promptEl.className = 'terminal-prompt'
    promptEl.textContent = `${prompt} `

    const codeEl = document.createElement('code')
    codeEl.className = 'terminal-command'

    row.append(promptEl, codeEl)
    return { row, codeEl, content }
  }

  const appendChunk = (parent, chunk) => {
    const span = document.createElement('span')
    span.textContent = chunk.text
    span.className = `terminal-token terminal-token--${chunk.color ?? 'default'}`
    if (chunk.bold) {
      span.classList.add('is-bold')
    }
    parent.append(span)
  }

  const createOutputLine = (line) => {
    const row = document.createElement('div')
    row.className = 'terminal-line terminal-line--output'
    const chunks = typeof line === 'string' ? [{ text: line, color: 'default', bold: false }] : line
    if (chunks.length === 1 && chunks[0]?.text === '') {
      row.innerHTML = '&nbsp;'
      return row
    }
    chunks.forEach((chunk) => appendChunk(row, chunk))
    return row
  }

  const createProgressLine = (label, color = 'cyan') => {
    const row = document.createElement('div')
    row.className = 'terminal-line terminal-line--progress'

    const spinner = document.createElement('span')
    spinner.className = `terminal-spinner terminal-token--${color}`
    spinner.textContent = '◐'

    const text = document.createElement('span')
    text.className = `terminal-token terminal-token--${color}`
    text.textContent = label

    row.append(spinner, text)
    return { row, spinner }
  }

  const typeText = async (node, content) => {
    node.textContent = ''
    for (const char of content) {
      node.textContent += char
      await sleep(18)
    }
  }

  const runScenario = async (panel, scenario) => {
    const stream = panel.querySelector(`[data-stream="${scenario.id}"]`)
    if (!(stream instanceof HTMLElement)) {
      return
    }

    stream.innerHTML = ''

    for (const event of scenario.events) {
      if (event.type === 'wait') {
        await sleep(event.delay)
        continue
      }

      if (event.type === 'prompt') {
        const { row, codeEl, content } = createPromptLine(event.content, event.prompt)
        stream.append(row)
        stream.scrollTop = stream.scrollHeight
        await typeText(codeEl, content)
        await sleep(event.delay ?? DEFAULT_PROMPT_DELAY)
        continue
      }

      if (event.type === 'output') {
        for (const line of event.content) {
          stream.append(createOutputLine(line))
          stream.scrollTop = stream.scrollHeight
          await sleep(74)
        }
        await sleep(event.delay ?? DEFAULT_OUTPUT_DELAY)
        continue
      }

      if (event.type === 'progress') {
        const { row, spinner } = createProgressLine(event.label, event.color)
        stream.append(row)
        stream.scrollTop = stream.scrollHeight
        const frames = ['◐', '◓', '◑', '◒']
        let index = 0
        const timer = window.setInterval(() => {
          spinner.textContent = frames[index % frames.length]
          index += 1
        }, 120)
        await sleep(event.delay)
        window.clearInterval(timer)
        row.remove()
      }
    }
  }

  document.querySelectorAll('[data-terminal-scene]').forEach((scene) => {
    const raw = scene.getAttribute('data-scenarios') ?? '[]'
    const scenarios = JSON.parse(raw)
    const tabs = [...scene.querySelectorAll('[data-tab]')]
    const panels = [...scene.querySelectorAll('[data-panel]')]
    const descriptions = [...scene.querySelectorAll('[data-description]')]
    let currentId = scenarios[0]?.id
    let cycleTimeout = 0
    let cycleRun = 0
    let autoCycleEnabled = true

    const syncState = (id) => {
      currentId = id
      tabs.forEach((tab) => tab.classList.toggle('is-active', tab.getAttribute('data-tab') === id))
      panels.forEach((panel) => panel.classList.toggle('is-active', panel.getAttribute('data-panel') === id))
      descriptions.forEach((item) => item.classList.toggle('is-active', item.getAttribute('data-description') === id))
    }

    const start = async (id) => {
      const runId = ++cycleRun
      const scenario = scenarios.find((item) => item.id === id)
      const panel = scene.querySelector(`[data-panel="${id}"]`)

      if (!scenario || !(panel instanceof HTMLElement)) {
        return
      }

      syncState(id)
      await runScenario(panel, scenario)

      if (runId !== cycleRun) {
        return
      }

      const currentIndex = scenarios.findIndex((item) => item.id === id)
      if (!autoCycleEnabled) {
        return
      }

      const next = scenarios[(currentIndex + 1) % scenarios.length]
      cycleTimeout = window.setTimeout(() => start(next.id), 10000)
    }

    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        const id = tab.getAttribute('data-tab')
        if (!id) {
          return
        }

        autoCycleEnabled = false
        window.clearTimeout(cycleTimeout)
        cycleRun += 1
        start(id)
      })
    })

    start(currentId)

    window.addEventListener(
      'beforeunload',
      () => {
        window.clearTimeout(cycleTimeout)
        cycleRun += 1
      },
      { once: true },
    )
  })
</script>

<style>
  .terminal-scene {
    display: flex;
    flex: 1 1 42rem;
    flex-direction: column;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 1.9rem;
    background: rgba(4, 9, 19, 0.92);
    box-shadow: 0 32px 90px rgba(7, 13, 26, 0.58);
  }

  .terminal-scene__chrome {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    padding: 0.9rem 1rem;
    background: rgba(255, 255, 255, 0.03);
  }

  .terminal-scene__chrome > span {
    width: 0.72rem;
    height: 0.72rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.16);
  }

  .terminal-scene__chrome > span:first-child {
    background: rgba(255, 109, 65, 0.84);
  }

  .terminal-scene__chrome > span:nth-child(2) {
    background: rgba(255, 181, 73, 0.84);
  }

  .terminal-scene__chrome > span:nth-child(3) {
    background: rgba(67, 238, 255, 0.84);
  }

  .terminal-scene__tabs {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    margin-left: 0.7rem;
  }

  .terminal-scene__tab {
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 999px;
    padding: 0.42rem 0.72rem;
    background: rgba(255, 255, 255, 0.03);
    font-family: var(--font-display);
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(177, 225, 255, 0.68);
    cursor: pointer;
    transition:
      border-color 160ms ease,
      background-color 160ms ease,
      color 160ms ease;
  }

  .terminal-scene__tab:hover {
    border-color: rgba(255, 255, 255, 0.14);
    color: rgba(235, 244, 255, 0.9);
    background: rgba(255, 255, 255, 0.05);
  }

  .terminal-scene__tab.is-active {
    border-color: rgba(255, 255, 255, 0.16);
    color: rgba(255, 255, 255, 0.92);
    background: rgba(255, 255, 255, 0.06);
  }

  .terminal-scene__meta {
    min-height: 3.4rem;
    padding: 0.95rem 1.15rem 0;
  }

  .terminal-scene__description {
    display: none;
    margin: 0;
    line-height: 1.7;
    color: rgba(224, 236, 255, 0.7);
  }

  .terminal-scene__description.is-active {
    display: block;
  }

  .terminal-scene__body {
    padding: 0 1.15rem 1.15rem;
  }

  .terminal-panel {
    display: none;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 1.35rem;
    background: rgba(8, 14, 29, 0.88);
    min-height: 24rem;
  }

  .terminal-panel.is-active {
    display: block;
  }

  .terminal-panel--cyan {
    box-shadow: inset 0 0 0 1px rgba(67, 238, 255, 0.06);
  }

  .terminal-panel--violet {
    box-shadow: inset 0 0 0 1px rgba(157, 97, 255, 0.08);
  }

  .terminal-panel--amber {
    box-shadow: inset 0 0 0 1px rgba(255, 181, 73, 0.08);
  }

  .terminal-stream {
    display: flex;
    flex-direction: column;
    gap: 0.08rem;
    min-height: 24rem;
    max-height: 24rem;
    overflow-y: auto;
    padding: 1.1rem;
    font-family: var(--font-code);
    font-size: 0.82rem;
    line-height: 1.5;
  }

  .terminal-line {
    min-height: 1.1rem;
    margin: 0;
    white-space: pre-wrap;
  }

  .terminal-line--prompt {
    display: flex;
    gap: 0.7rem;
    align-items: center;
    color: rgba(235, 244, 255, 0.96);
  }

  .terminal-line--progress {
    display: inline-flex;
    gap: 0.7rem;
    align-items: center;
  }

  .terminal-prompt {
    color: rgba(67, 238, 255, 0.92);
    white-space: pre;
  }

  .terminal-command {
    color: rgba(235, 244, 255, 0.96);
    white-space: pre-wrap;
  }

  .terminal-spinner {
    width: 1rem;
    text-align: center;
  }

  .terminal-token {
    color: rgba(223, 236, 255, 0.82);
    white-space: pre-wrap;
  }

  .terminal-token.is-bold {
    font-weight: 700;
  }

  .terminal-token--default,
  .terminal-token--white {
    color: rgba(235, 244, 255, 0.94);
  }

  .terminal-token--muted {
    color: rgba(197, 211, 229, 0.66);
  }

  .terminal-token--cyan {
    color: rgba(67, 238, 255, 0.92);
  }

  .terminal-token--violet {
    color: rgba(196, 166, 255, 0.92);
  }

  .terminal-token--amber {
    color: rgba(255, 191, 98, 0.92);
  }

  .terminal-token--green {
    color: rgba(112, 246, 177, 0.94);
  }

  .terminal-token--red {
    color: rgba(255, 130, 130, 0.9);
  }
</style>
