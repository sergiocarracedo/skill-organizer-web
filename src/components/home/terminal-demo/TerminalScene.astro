---
import type { TerminalBlock } from '@/data/home'

type Props = {
  blocks: TerminalBlock[]
}

const { blocks } = Astro.props as Props
---

<div class='terminal-scene' data-reveal>
  <div class='terminal-scene__chrome'>
    <span></span>
    <span></span>
    <span></span>
    <p>install + onboard simulation</p>
  </div>

  <div class='terminal-scene__body'>
    {blocks.map((block) => (
      <section class:list={['terminal-block', `terminal-block--${block.accent}`]}>
        <p class='terminal-block__title'>{block.title}</p>
        <div class='terminal-block__command'>
          <span>$</span>
          <code>{block.command}</code>
        </div>
        <pre class='terminal-block__output'><code>{block.output.join('\n')}</code></pre>
      </section>
    ))}
  </div>
</div>

<style>
  .terminal-scene {
    display: flex;
    flex: 1 1 42rem;
    flex-direction: column;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 1.9rem;
    background: rgba(4, 9, 19, 0.92);
    box-shadow: 0 32px 90px rgba(7, 13, 26, 0.58);
  }

  .terminal-scene__chrome {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    padding: 0.9rem 1rem;
    background: rgba(255, 255, 255, 0.03);
  }

  .terminal-scene__chrome span {
    width: 0.72rem;
    height: 0.72rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.16);
  }

  .terminal-scene__chrome span:first-child {
    background: rgba(255, 109, 65, 0.84);
  }

  .terminal-scene__chrome span:nth-child(2) {
    background: rgba(255, 181, 73, 0.84);
  }

  .terminal-scene__chrome span:nth-child(3) {
    background: rgba(67, 238, 255, 0.84);
  }

  .terminal-scene__chrome p {
    margin-left: 0.7rem;
    font-family: var(--font-display);
    font-size: 0.78rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(177, 225, 255, 0.7);
  }

  .terminal-scene__body {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: 1.15rem;
  }

  .terminal-block {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 1.25rem;
    padding: 1.05rem 1.1rem;
    background: rgba(8, 14, 29, 0.88);
  }

  .terminal-block--cyan {
    box-shadow: inset 0 0 0 1px rgba(67, 238, 255, 0.06);
  }

  .terminal-block--violet {
    box-shadow: inset 0 0 0 1px rgba(157, 97, 255, 0.08);
  }

  .terminal-block--amber {
    box-shadow: inset 0 0 0 1px rgba(255, 181, 73, 0.08);
  }

  .terminal-block__title {
    font-family: var(--font-display);
    font-size: 0.78rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(177, 225, 255, 0.66);
  }

  .terminal-block__command {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    color: rgba(235, 244, 255, 0.96);
    font-family: var(--font-code);
    font-size: 0.92rem;
  }

  .terminal-block__command span {
    color: rgba(67, 238, 255, 0.92);
  }

  .terminal-block__output {
    overflow-x: auto;
    font-family: var(--font-code);
    font-size: 0.84rem;
    line-height: 1.75;
    color: rgba(223, 236, 255, 0.78);
  }
</style>
